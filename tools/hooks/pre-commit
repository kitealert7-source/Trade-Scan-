#!/bin/sh
# Pre-commit hook -- tracked canonical source.
# Install into this clone with `./tools/hooks/install.sh`.
#
# Steps run in order; the first non-zero exit blocks the commit.
#   1. Hardcoded user-path scan
#   2. Bare .read_text() scan
#   3. Bare `return True` in check_exit() (warn-only, never blocks)
#   4. RESEARCH_MEMORY parse-integrity check
#   5. Gate test suite
#   6. Regression harness (selective -- only when staged paths touch a
#      layer the harness covers)

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "[pre-commit] Scanning staged .py files for hardcoded user paths..."
python "$REPO_ROOT/tools/lint_no_hardcoded_paths.py" --staged
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] COMMIT BLOCKED. Fix the hardcoded paths above before committing."
    exit 1
fi

echo "[pre-commit] Scanning staged .py files for bare .read_text()..."
python "$REPO_ROOT/tools/lint_encoding.py" --staged
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] COMMIT BLOCKED. Use .read_text(encoding=\"utf-8\") instead."
    exit 1
fi

echo "[pre-commit] Scanning staged strategy.py for bare \`return True\` in check_exit (warn-only)..."
python "$REPO_ROOT/tools/lint_check_exit_labels.py" --staged
# warn-only -- never blocks the commit (exit code is always 0)

echo "[pre-commit] Validating RESEARCH_MEMORY parse integrity..."
python "$REPO_ROOT/tools/generate_research_memory_index.py" --check
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] COMMIT BLOCKED. RESEARCH_MEMORY has parse errors — fix before committing."
    exit 1
fi

echo "[pre-commit] Running gate test suite..."
python -m pytest tests/test_idea_evaluation_gate.py tests/test_namespace_gate_regex.py tests/test_sweep_registry_gate_regex.py tests/test_burnin_evaluator.py -q --maxfail=1 2>&1
if [ $? -ne 0 ]; then
    echo ""
    echo "[pre-commit] COMMIT BLOCKED. Gate tests failed — fix before committing."
    exit 1
fi

# --- engine-dev manifest sync guard --------------------------------------
# Any change under engine_dev/universal_research_engine/<version>/ MUST be
# accompanied by an updated engine_manifest.json in the same version dir.
# This prevents the f3ae767-class drift where engine source was modified
# post-freeze without manifest regeneration.
ENGINE_DEV_CHANGES="$(git diff --cached --name-only --diff-filter=ACMRT \
    | grep -E '^engine_dev/universal_research_engine/v[^/]+/' || true)"
if [ -n "$ENGINE_DEV_CHANGES" ]; then
    echo "[pre-commit] engine_dev/universal_research_engine/ changes detected — checking manifest sync..."
    MISSING_MANIFEST_VERSIONS=""
    # Collect every version directory touched in the staged set
    TOUCHED_VERSIONS="$(echo "$ENGINE_DEV_CHANGES" \
        | sed -E 's|^(engine_dev/universal_research_engine/v[^/]+)/.*$|\1|' \
        | sort -u)"
    for VERSION_DIR in $TOUCHED_VERSIONS; do
        # If any non-manifest file in this version dir is staged, the manifest
        # for the same dir must also be staged.
        NON_MANIFEST_STAGED="$(echo "$ENGINE_DEV_CHANGES" \
            | grep "^${VERSION_DIR}/" \
            | grep -v "/engine_manifest.json$" || true)"
        MANIFEST_STAGED="$(echo "$ENGINE_DEV_CHANGES" \
            | grep "^${VERSION_DIR}/engine_manifest.json$" || true)"
        if [ -n "$NON_MANIFEST_STAGED" ] && [ -z "$MANIFEST_STAGED" ]; then
            MISSING_MANIFEST_VERSIONS="${MISSING_MANIFEST_VERSIONS}${VERSION_DIR}\n"
        fi
    done
    if [ -n "$MISSING_MANIFEST_VERSIONS" ]; then
        echo ""
        echo "[pre-commit] COMMIT BLOCKED. Engine source changed without manifest update."
        echo ""
        echo "  The following engine version directories have staged source changes"
        echo "  but no corresponding engine_manifest.json update in the same commit:"
        echo ""
        printf "    %b" "$MISSING_MANIFEST_VERSIONS"
        echo ""
        echo "  Root cause: f3ae767 (Apr 23) shipped engine source changes to v1.5.8"
        echo "  without regenerating its manifest, breaking integrity verification"
        echo "  for all subsequent backtest runs. This guard prevents recurrence."
        echo ""
        echo "  Fix: regenerate the manifest for each version above and stage it"
        echo "  alongside the source change:"
        echo ""
        for VERSION_DIR in $TOUCHED_VERSIONS; do
            VNAME=\$(basename \"$VERSION_DIR\")
            echo "    python tools/generate_engine_manifest.py --version $(basename "$VERSION_DIR")"
            echo "    git add ${VERSION_DIR}/engine_manifest.json"
        done
        echo ""
        echo "  If the source change is intentional and the manifest is deliberately"
        echo "  unchanged (e.g. comment-only edit), explicitly stage the manifest"
        echo "  unchanged: git add ${VERSION_DIR}/engine_manifest.json (no-op stage)."
        echo ""
        exit 1
    fi
    echo "[pre-commit] engine-dev manifest sync OK — all touched versions have manifest staged."
fi

# --- regression harness (selective) --------------------------------------
# Run tools/regression only when staged paths touch a layer the harness
# actually covers. Unrelated commits (docs, governance, engine_dev, etc.)
# are unaffected.
STAGED="$(git diff --cached --name-only --diff-filter=ACMRT)"
if echo "$STAGED" | grep -E '^tools/(capital|portfolio|report|promote)/' > /dev/null; then
    echo "[pre-commit] Regression harness triggered (capital/portfolio/report/promote touched)..."
    PYTHONHASHSEED=0 MPLBACKEND=Agg python -m tools.regression.cli
    if [ $? -ne 0 ]; then
        echo ""
        echo "[pre-commit] COMMIT BLOCKED. Regression harness failed."
        echo ""
        echo "  Run:"
        echo "    python -m tools.regression.cli"
        echo ""
        echo "  See diffs:"
        echo "    tools/regression/tmp/*/DIFF_*.txt"
        echo ""
        exit 1
    fi
else
    echo "[pre-commit] Regression harness skipped (no capital/portfolio/report/promote changes)."
fi

exit 0
