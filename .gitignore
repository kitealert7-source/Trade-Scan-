# ===== Secrets & Credentials (CRITICAL — never commit) =====
.secrets/
*.env
*.key
*.pem
*.secret

# Runtime artifacts (never commit)
backtests/
runs/
results/
# Anchored: `/research/` matches only the top-level `research/`
# directory (idea-scratch text files). The unanchored form silently
# excluded `tools/utils/research/` (6 production modules imported by
# tracked code) for an unknown duration. See
# outputs/TOOLS_GITIGNORE_AUDIT.md (2026-05-12).
/research/

# Market & raw data
MASTER_DATA/
data/
.cache/
data_root/MASTER_DATA/

# data_root runtime files (updated by pipeline on every run — not source-controlled)
data_root/freshness_index.json
data_root/SYSTEM_FACTORS/
data_root/governance/last_successful_daily_run.json
data_root/EXTERNAL_DATA/
data_root/JPY_SYNTH/
data_root/.research_regen_backup/

# Strategy snapshots (runtime mirrors)
strategies/

# Python junk
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
tmp_*
venv/
.venv/
*_venv/
*.egg-info/
*.bak

# Canonicalizer staging (cross-platform replacement for /tmp)
.canonical_staging/

# OS junk
.DS_Store
Thumbs.db

# Ignore generated CSVs everywhere
*.csv

# ---- VAULT RULE ----
# Vault is tracked EXCEPT transient junk (if any)
!vault/
!vault/ENGINE_VAULT_CONTRACT.md
!vault/engines/
!vault/engines/**

# Dry-run workspace snapshots — large archive artifacts, not source-controlled
vault/snapshots/
vault/snapshots_pre_edit/

# Refactor scratch artifacts (large-file remediation working set)
outputs/refactor_baseline/
outputs/system_reports/01_system_architecture/LARGE_FILE_REFACTOR_PLAN.md
outputs/system_reports/01_system_architecture/LARGE_FILE_SUMMARY.json

tmp/

# External runtime state
../TradeScan_State/
TradeScan_State/

# Runtime folders
sandbox/
reports_summary/

# ===== Directive rules =====
# Active directives: never commit (work-in-progress)
backtest_directives/active/*.txt
backtest_directives/ACTIVE/
backtest_directives/active_backup/
!backtest_directives/active/README.md
# Completed directives: NOT tracked. Since 60862b4c every basket run self-contains a
# byte-identical DIRECTIVE_SOURCE.txt + RECYCLE_RULE_SOURCE.py under
# TradeScan_State/backtests/<run>/, so the git corpus is redundant and only re-churned
# git history on each cohort regen (~18k blob versions for a ~1.5k working set).
# Use /* + negation so the one legacy straggler with no run-folder home stays tracked
# (git is its only spec copy).
# >>> CONTRACT before re-adding the corpus: reproducibility was NOT lost. See
# governance/SOP/EXECUTION_CAPSULE_CONTRACT.md
backtest_directives/completed/*
!backtest_directives/completed/90_PORT_H2_5M_RECYCLE_S01_V1_P00.txt
# *.admitted: 0-byte pipeline markers, no value in git
*.admitted
# Episode staging: scratch pre-INBOX corpus generation, regenerable via the
# episode generator. Not a spec record (completed/ is). Do not track.
# Glob covers the base dir plus arm-suffixed variants (_hf55_, _hl120_, _lm20_, ...).
backtest_directives/cointrev_v3_*staging/

# Data artifacts
*.parquet
*.h5
*.pickle

# Environment metadata
# .claude/ is machine-local except for skills/ and hooks/ (shared
# enforcement infrastructure). Pattern uses .claude/* (not .claude/)
# so the negation below can re-include specific subdirectories —
# git cannot re-include anything beneath an excluded parent directory.
.claude/*
!.claude/skills/
!.claude/hooks/
.agents/
.vscode/
.idea/

# ===== Generated outputs =====
outputs/logs/
outputs/proposals/
outputs/audit_reports/
outputs/audit\ _reports/
outputs/.session_state/pipeline_telemetry/
outputs/.session_state/broader_pytest_durations.jsonl
# Daily/4h cointegration screener snapshots — regenerable pipeline output
# (boot-triggered; P3 Excel ~8.6MB each). Source of truth is cointegration.db.
outputs/cointegration_screener_v1/

# ===== Logs =====
*.log
logs/

# ===== Governance / directive runtime state =====
# INBOX: pending directives awaiting pipeline pickup (ephemeral queue).
# *.jsonl under governance/: append-only event/audit logs emitted at runtime
# (events.jsonl, stop_contract_audit.jsonl, etc.). Source of truth is the
# code that writes them, not the log itself.
backtest_directives/INBOX/
governance/*.jsonl

# ===== Ad-hoc review artefacts =====
# Generated audit reports (docx / pdf deliverables) are ephemeral — the
# source of truth is the code + tests, not the report.
outputs/*.docx
outputs/*.pdf
archive/**/*.docx

# ===== Backups =====
*.backup
*.r*_backup_*
# Stale capital-sim wrapper backups (live tools/capital_wrapper.py is tracked; history holds all versions)
archive/tools/capital_wrapper_backups/
*.scaling_backup_*
*.uniform_backup_*
*.uniform_multi_backup_*

# ===== Specific tool scripts (local utility, not part of pipeline) =====
tools/new_pass.py
tools/regenerate_all_reports.py
tools/sync_portfolio_flags.py

# ===== Stale renamed files =====
gitignore.txt
